#!/bin/sh
# AI Code Review Pre-commit Hook
# 基于 ai-skills 规范的本地代码审查
# 安装: cp scripts/pre-commit .git/hooks/ && chmod +x .git/hooks/pre-commit

echo "🔍 Running AI Code Review pre-commit hook..."

# 获取暂存区的变更文件
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' | grep -E '^(src/features/|src/pages/)' || true)

if [ -z "$STAGED_FILES" ]; then
    echo "✅ No relevant files to review"
    exit 0
fi

echo "📁 Files to review:"
echo "$STAGED_FILES" | while read file; do
    echo "  - $file"
done
echo ""

# 创建临时目录存放要审查的文件
TEMP_DIR=$(mktemp -d)
trap "rm -rf $TEMP_DIR" EXIT

# 将暂存区的文件复制到临时目录
for file in $STAGED_FILES; do
    mkdir -p "$TEMP_DIR/$(dirname $file)"
    git show ":$file" > "$TEMP_DIR/$file" 2>/dev/null || true
done

# 运行审查脚本
if [ -f "scripts/code-review-bot.js" ]; then
    # 切换到临时目录运行审查
    cd "$TEMP_DIR"
    
    # 创建简化版的审查脚本用于本地
    node -e "
const fs = require('fs');
const path = require('path');

const RULES = {
  blocking: [
    {
      id: 'BC-1',
      pattern: /request\s*\(|fetch\s*\(|axios\./,
      filePattern: /src\/pages\//,
      message: '🔴 BC-1: Page 层禁止直接调用 API',
    },
    {
      id: 'BC-2',
      pattern: /types\.ts$/,
      filePattern: /src\/pages\//,
      message: '🔴 BC-2: Page 层禁止定义类型文件',
    },
    {
      id: 'BC-3',
      pattern: /from\s+['\"]@\/features\/[^'\"]+\/_/,
      message: '🔴 BC-3: 禁止直接引用其他 feature 的私有文件',
    },
  ],
  suggestion: [
    {
      id: 'SG-1',
      pattern: /:\s*any\b/,
      message: '🟡 SG-1: 发现 any 类型使用',
    },
    {
      id: 'SG-2',
      pattern: /destroyOnClose/,
      message: '🟡 SG-3: 发现废弃属性 destroyOnClose',
    },
  ],
};

function reviewFile(filePath, content) {
  const issues = [];
  const lines = content.split('\n');
  
  for (const rule of RULES.blocking) {
    if (rule.filePattern && !rule.filePattern.test(filePath)) continue;
    
    lines.forEach((line, index) => {
      if (rule.pattern.test(line)) {
        issues.push({
          level: 'blocking',
          ruleId: rule.id,
          line: index + 1,
          message: rule.message,
          code: line.trim(),
        });
      }
    });
  }
  
  for (const rule of RULES.suggestion) {
    lines.forEach((line, index) => {
      if (rule.pattern.test(line)) {
        issues.push({
          level: 'suggestion',
          ruleId: rule.id,
          line: index + 1,
          message: rule.message,
          code: line.trim(),
        });
      }
    });
  }
  
  return issues;
}

const files = process.argv.slice(1);
let allIssues = [];

for (const file of files) {
  try {
    const content = fs.readFileSync(file, 'utf8');
    const issues = reviewFile(file, content);
    for (const issue of issues) {
      allIssues.push({ ...issue, file });
    }
  } catch (e) {}
}

const blockingCount = allIssues.filter(i => i.level === 'blocking').length;
const suggestionCount = allIssues.filter(i => i.level === 'suggestion').length;

if (allIssues.length > 0) {
  console.log('\\n📊 Review Results:');
  console.log('  🔴 Blocking: ' + blockingCount);
  console.log('  🟡 Suggestion: ' + suggestionCount);
  console.log('');
  
  for (const issue of allIssues) {
    console.log('\\n' + issue.message);
    console.log('  File: ' + issue.file + ':' + issue.line);
    console.log('  Code: ' + issue.code);
  }
  
  if (blockingCount > 0) {
    console.log('\\n❌ Commit blocked: Please fix blocking issues');
    process.exit(1);
  } else {
    console.log('\\n⚠️  Suggestions found but commit allowed');
  }
} else {
  console.log('✅ All checks passed');
}
" $STAGED_FILES
    
    EXIT_CODE=$?
    cd - > /dev/null
    
    if [ $EXIT_CODE -ne 0 ]; then
        echo ""
        echo "💡 To bypass this check (not recommended):"
        echo "   git commit --no-verify"
        exit 1
    fi
else
    echo "⚠️  Review script not found, skipping"
fi

echo "✅ Pre-commit review passed"
exit 0
